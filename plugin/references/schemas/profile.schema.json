{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Profile",
  "type": "object",
  "required": ["schema_version", "metadata"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "metadata": {
      "type": "object",
      "required": ["generated_by", "last_updated"],
      "properties": {
        "generated_by": { "const": "guardians-of-the-claude" },
        "last_updated": { "type": "string", "format": "date-time" },
        "source_files_checked": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "runtime_and_language": {
      "type": ["object", "null"],
      "properties": {
        "runtime": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "module_system": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "framework_and_libraries": {
      "type": ["object", "null"],
      "properties": {
        "framework": { "type": ["string", "null"] },
        "ui": { "type": ["string", "null"] },
        "styling": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "package_management": {
      "type": ["object", "null"],
      "properties": {
        "manager": { "type": ["string", "null"] },
        "lock_file": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "testing": {
      "type": ["object", "null"],
      "properties": {
        "unit": { "type": ["string", "null"] },
        "e2e": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "build_and_dev": {
      "type": ["object", "null"],
      "properties": {
        "bundler": { "type": ["string", "null"] },
        "linter": { "type": ["string", "null"] },
        "formatter": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "project_structure": {
      "type": ["object", "null"],
      "properties": {
        "type": { "enum": ["single_project", "monorepo", null] },
        "source_convention": { "type": ["string", "null"] },
        "key_directories": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "claude_code_configuration_state": {
      "type": ["object", "null"],
      "properties": {
        "claude_md": { "type": "object" },
        "settings_json": { "type": "object" },
        "rules_count": { "type": "integer", "minimum": 0 },
        "agents_count": { "type": "integer", "minimum": 0 },
        "hooks_count": { "type": "integer", "minimum": 0 },
        "mcp_servers_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
